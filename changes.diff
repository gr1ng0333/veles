+    def _maybe_alert_import_failure(self, module_name: str, import_result: str) -> None:
+        """Send one Telegram alert per module per audit cycle when import fails."""
+        if import_result == 'OK':
+            return
+        if self._event_queue is None:
+            return
+        chat_id = self._owner_chat_id_fn()
+        if chat_id is None:
+            return
+        alerted_key = f"alerted_{module_name}"
+        if self._audit_state.get(alerted_key):
+            return
+        self._audit_state[alerted_key] = True
+        _save_audit_state(self._audit_state_path, self._audit_state)
+        err_short = import_result[:300].strip()
+        nl = chr(10)
+        text = nl.join([
+            "\U0001f6a8 Auditor: import failed",
+            f"<code>{module_name}</code>",
+            f"<code>{err_short}</code>",
+            "",
+            "Module will crash at runtime. Check /healthcheck for details.",
+        ])
+        try:
+            self._event_queue.put({
+                "type": "send_message",
+                "chat_id": chat_id,
+                "text": text,
+                "format": "html",
+                "is_progress": False,
+                "chat_scope": "main",
+            })
+            append_jsonl(self._drive_root / "logs" / "events.jsonl", {
+                "ts": utc_now_iso(),
+                "type": "consciousness_alert",
+                "module": module_name,
+                "reason": "import_failed",
+                "error": import_result[:200],
+            })
+        except Exception as e:
+            log.warning("Failed to send consciousness alert: %s", e)
+
